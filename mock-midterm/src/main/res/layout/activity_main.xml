<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/purple_dark">

    <!-- DISPLAY AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="20dp"
        android:background="@color/purple_dark">

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/purple_muted"
            android:textSize="14sp"
            android:gravity="end"
            android:text=""
            android:maxLines="2"/>

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/purple_muted"
            android:textSize="16sp"
            android:gravity="end"
            android:text=""/>

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/purple_text"
            android:textSize="52sp"
            android:fontFamily="monospace"
            android:gravity="end"
            android:text="0"/>
    </LinearLayout>

    <!-- BUTTON GRID -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:columnCount="4"
        android:rowCount="6"
        android:padding="12dp"
        android:background="@color/purple_deep">

        <!-- Row 1: AC  +/-  %  ÷ -->
        <Button android:id="@+id/btnAC"    style="@style/CalcBtnClear"  android:text="AC"/>
        <Button android:id="@+id/btnSign"  style="@style/CalcBtnClear"  android:text="+/-"/>
        <Button android:id="@+id/btnMod"   style="@style/CalcBtnClear"  android:text="%"/>
        <Button android:id="@+id/btnDiv"   style="@style/CalcBtnOp"     android:text="÷"/>

        <!-- Row 2: 7 8 9 × -->
        <Button android:id="@+id/btn7"     style="@style/CalcBtnNum"    android:text="7"/>
        <Button android:id="@+id/btn8"     style="@style/CalcBtnNum"    android:text="8"/>
        <Button android:id="@+id/btn9"     style="@style/CalcBtnNum"    android:text="9"/>
        <Button android:id="@+id/btnMul"   style="@style/CalcBtnOp"     android:text="×"/>

        <!-- Row 3: 4 5 6 − -->
        <Button android:id="@+id/btn4"     style="@style/CalcBtnNum"    android:text="4"/>
        <Button android:id="@+id/btn5"     style="@style/CalcBtnNum"    android:text="5"/>
        <Button android:id="@+id/btn6"     style="@style/CalcBtnNum"    android:text="6"/>
        <Button android:id="@+id/btnSub"   style="@style/CalcBtnOp"     android:text="−"/>

        <!-- Row 4: 1 2 3 + -->
        <Button android:id="@+id/btn1"     style="@style/CalcBtnNum"    android:text="1"/>
        <Button android:id="@+id/btn2"     style="@style/CalcBtnNum"    android:text="2"/>
        <Button android:id="@+id/btn3"     style="@style/CalcBtnNum"    android:text="3"/>
        <Button android:id="@+id/btnAdd"   style="@style/CalcBtnOp"     android:text="+"/>

        <!-- Row 5: 0 (span 2)  .  = -->
        <Button android:id="@+id/btn0"
            style="@style/CalcBtnNum"
            android:text="0"
            android:layout_columnSpan="2"
            android:layout_gravity="fill"/>
        <Button android:id="@+id/btnDot"   style="@style/CalcBtnNum"    android:text="."/>
        <Button android:id="@+id/btnEq"    style="@style/CalcBtnEq"     android:text="="/>

        <!-- Row 6: BERAM custom operator (full width) -->
        <Button android:id="@+id/btnBeram"
            style="@style/CalcBtnBeram"
            android:text="★ BERAM × 1.40"
            android:layout_columnSpan="4"
            android:layout_gravity="fill"/>

    </GridLayout>
</LinearLayout>