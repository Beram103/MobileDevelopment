<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base button style | beram calc | Amber 24103140 -->
    <style name="CalcBtnBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="CalcBtnNum" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/purple_deep</item>
        <item name="android:textColor">@color/purple_text</item>
    </style>

    <style name="CalcBtnOp" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/purple_mid</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="CalcBtnClear" parent="CalcBtnBase">
        <item name="android:backgroundTint">#3d1060</item>
        <item name="android:textColor">@color/purple_accent</item>
    </style>

    <style name="CalcBtnEq" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/purple_bright</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="CalcBtnBeram" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/purple_mid</item>
        <item name="android:textColor">#ffd6ff</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_rowWeight">0.7</item>
    </style>
</resources>